# PostgreSQL (pgvector 이미지 사용 시 docker-compose와 동일 계정 권장)
DATABASE_URL=postgresql+psycopg2://office:office@localhost:5432/office_guide

# API
API_V1_PREFIX=/api/v1

# 임베딩 차원 — Alembic 초기 마이그레이션과 반드시 일치해야 함
EMBEDDING_DIMENSION=1536

# 로컬 개발용 파일 스토리지 (Phase 1 최소 구현)
STORAGE_ROOT=./var/storage

# OpenAI (임베딩: text-embedding-3-small)
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# 인제스천 휴리스틱
OCR_TEXT_THRESHOLD_CHARS=80
CHUNK_TARGET_TOKENS=700
CHUNK_MAX_TOKENS=1200
OCR_LANG=kor+eng
